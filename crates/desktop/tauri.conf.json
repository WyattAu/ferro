{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.11/crates/tauri-config-schema/schema.json",
  "productName": "Ferro",
  "version": "3.0.0",
  "identifier": "com.wyattau.ferro",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ferro",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' http: https: ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright 2024 Ferro Contributors",
    "category": "Utility",
    "shortDescription": "Ferro File Sync",
    "longDescription": "Secure self-hosted file synchronization client",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "dmg": {
        "appPosition": {
          "x": 480,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 180,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "gtk3",
          "webkit2gtk4.1",
          "libayatana-appindicator-gtk3"
        ]
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "both"
      },
      "wix": null
    },
    "iOS": {
      "developmentTeam": "",
      "minimumSystemVersion": "14.0"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [
        "https://github.com/WyattAu/ferro/releases/latest/download/latest.json"
      ]
    }
  }
}