{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.11/crates/tauri-config-schema/schema.json",
  "productName": "Ferro",
  "version": "3.0.0",
  "identifier": "com.ferro.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ferro",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost 'self' https://* http://*"
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright 2024 Ferro Contributors",
    "category": "Utility",
    "shortDescription": "Ferro File Sync",
    "longDescription": "Secure self-hosted file synchronization client",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "both",
        "language": null,
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": null,
        "displayLanguageSelector": false,
        "bannerImage": null
      },
      "wix": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://github.com/WyattAu/ferro/releases/latest/download/latest.json"
      ]
    }
  }
}
