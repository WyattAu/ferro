#!/bin/sh
# Ferro pre-commit hook: fmt + clippy quality gates.
# Full test suite runs in CI (checks.yml) -- not locally, to keep commits fast.
# Override: SKIP_PRECOMMIT=1 git commit ...

set -euo pipefail

if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
  echo "[pre-commit] Skipped (SKIP_PRECOMMIT=1)"
  exit 0
fi

echo "[pre-commit] (1/2) Checking formatting..."
cargo fmt --all -- --check

echo "[pre-commit] (2/2) Running clippy..."
cargo clippy --workspace --all-targets --features "s3,gcs,azure,pg,redis,ldap" --locked -- -D warnings

echo "[pre-commit] All checks passed."
