#!/bin/sh
# Ferro pre-commit hook: fmt + clippy + targeted tests.
#
# Stages:
#   (1/3) Formatting (cargo fmt)
#   (2/3) Linting  (cargo clippy --deny warnings)
#   (3/3) Tests    (cargo test on crates that changed vs HEAD)
#
# Override: SKIP_PRECOMMIT=1 git commit ...
# Run full test suite locally: PRECOMMIT_FULL_TESTS=1 git commit ...

set -euo pipefail

if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
  echo "[pre-commit] Skipped (SKIP_PRECOMMIT=1)"
  exit 0
fi

PASS=0
FAIL=0

check_step() {
  if "$@" 2>/dev/null; then
    PASS=$((PASS + 1))
    return 0
  else
    FAIL=$((FAIL + 1))
    echo "[pre-commit] FAILED: $*"
    return 1
  fi
}

echo "========================================="
echo "[pre-commit] Ferro quality gates"
echo "========================================="

echo ""
echo "[pre-commit] (1/3) Checking formatting..."
check_step cargo fmt --all -- --check

echo ""
echo "[pre-commit] (2/3) Running clippy..."
check_step cargo clippy --workspace --all-targets \
  --features "s3,gcs,azure,pg,redis,ldap" \
  --locked -- -D warnings

echo ""
echo "[pre-commit] (3/3) Running tests..."
if [ "${PRECOMMIT_FULL_TESTS:-0}" = "1" ]; then
  echo "[pre-commit] Full test suite requested (PRECOMMIT_FULL_TESTS=1)"
  check_step cargo test --workspace --locked
else
  # Determine which crates changed (staged + unstaged)
  CHANGED=$(git diff --name-only HEAD 2>/dev/null | grep '^crates/' | cut -d/ -f2 | sort -u || true)
  if [ -z "$CHANGED" ]; then
    echo "[pre-commit] No crate changes detected, running workspace tests..."
    check_step cargo test --workspace --locked
  else
    echo "[pre-commit] Testing changed crates: $(echo $CHANGED | tr '\n' ' ')"
    TEST_FAILED=0
    for CRATE in $CHANGED; do
      # Try ferro-$CRATE first, fall back to bare $CRATE
      if cargo test -p "ferro-${CRATE}" --locked 2>/dev/null; then
        : # pass
      elif cargo test -p "${CRATE}" --locked 2>/dev/null; then
        : # pass
      else
        TEST_FAILED=1
      fi
    done
    if [ "$TEST_FAILED" -ne 0 ]; then
      FAIL=$((FAIL + 1))
      echo "[pre-commit] FAILED: some crate tests failed"
    else
      PASS=$((PASS + 1))
    fi
  fi
fi

echo ""
echo "========================================="
echo "[pre-commit] Results: ${PASS} passed, ${FAIL} failed"
echo "========================================="

if [ "$FAIL" -gt 0 ]; then
  echo "[pre-commit] Commit blocked. Fix the errors above or use SKIP_PRECOMMIT=1."
  exit 1
fi

echo "[pre-commit] All quality gates passed."
