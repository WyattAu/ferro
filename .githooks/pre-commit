#!/bin/sh
# Ferro pre-commit hook: quality gates + tests before commit.
# Ensures fmt, clippy, and all tests pass locally before pushing.
# Override: SKIP_PRECOMMIT=1 git commit ...

set -euo pipefail

if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
  echo "[pre-commit] Skipped (SKIP_PRECOMMIT=1)"
  exit 0
fi

echo "[pre-commit] (1/3) Checking formatting..."
cargo fmt --all -- --check

echo "[pre-commit] (2/3) Running clippy..."
cargo clippy --workspace --all-targets --features "s3,gcs,azure,pg,redis,ldap" -- -D warnings

echo "[pre-commit] (3/3) Running tests..."
cargo test --all --locked

echo "[pre-commit] All checks passed."
