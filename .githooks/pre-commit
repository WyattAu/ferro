#!/bin/sh
# Ferro pre-commit hook: fast quality gates before commit.
# Full test suite + deny run in CI. This hook catches fmt/clippy regressions early.
# Override: SKIP_PRECOMMIT=1 git commit ...

set -euo pipefail

if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
  echo "[pre-commit] Skipped (SKIP_PRECOMMIT=1)"
  exit 0
fi

echo "[pre-commit] Checking formatting..."
cargo fmt --all -- --check

echo "[pre-commit] Running clippy..."
cargo clippy --workspace --all-targets --features "s3,gcs,azure,pg,redis,ldap" -- -D warnings

echo "[pre-commit] Passed. Full tests + cargo-deny run in CI."
