#!/usr/bin/env bash
# Ferro pre-commit hook: fmt + clippy + targeted tests + security scan.
#
# Stages:
#   (1/5) Formatting (cargo fmt --all)
#   (2/5) Linting  (cargo clippy on changed crates, full workspace if none)
#   (3/5) Secret scan (detect hardcoded secrets in staged code)
#   (4/5) TODO/FIXME scan (detect incomplete work markers)
#   (5/5) Tests    (cargo test on changed crates only, skip if none)
#
# Override: SKIP_PRECOMMIT=1 git commit ...
# Skip specific stages: SKIP_CLIPPY=1 SKIP_TESTS=1 SKIP_SECRET_SCAN=1 git commit ...

set -euo pipefail

if [ "${SKIP_PRECOMMIT:-0}" = "1" ]; then
  echo "[pre-commit] Skipped (SKIP_PRECOMMIT=1)"
  exit 0
fi

PASS=0
FAIL=0
WARN=0
START_TIME=$(date +%s)

check_step() {
  local stage_name="$1"
  shift
  if "$@" 2>/dev/null; then
    PASS=$((PASS + 1))
    return 0
  else
    FAIL=$((FAIL + 1))
    echo "[pre-commit] FAILED: $stage_name"
    return 1
  fi
}

echo "========================================="
echo "[pre-commit] Ferro quality gates"
echo "========================================="

# ── Stage 1: Formatting ──
echo ""
echo "[pre-commit] (1/5) Checking formatting..."
check_step "cargo fmt" cargo fmt --all -- --check

# ── Stage 2: Linting ──
if [ "${SKIP_CLIPPY:-0}" != "1" ]; then
  echo ""
  echo "[pre-commit] (2/5) Running clippy..."
  CLIPPY_CHANGED=$(git diff --cached --name-only HEAD 2>/dev/null | grep '^crates/' | cut -d/ -f2 | sort -u || true)
  CLIPPY_FAILED=0
  if [ -n "$CLIPPY_CHANGED" ]; then
    echo "[pre-commit] Clippy on changed crates: $(echo $CLIPPY_CHANGED | tr '\n' ' ')"
    for CRATE in $CLIPPY_CHANGED; do
      # Try ferro-$CRATE first, fall back to bare $CRATE
      if ! (cargo clippy -p "ferro-${CRATE}" --all-targets \
        --features "s3,gcs,azure,pg,redis,ldap" \
        --locked -- -D warnings 2>/dev/null || \
        cargo clippy -p "${CRATE}" --all-targets \
        --features "s3,gcs,azure,pg,redis,ldap" \
        --locked -- -D warnings 2>/dev/null); then
        CLIPPY_FAILED=1
      fi
    done
  else
    echo "[pre-commit] No crate changes detected, running clippy on full workspace..."
    if ! cargo clippy --workspace --all-targets \
      --features "s3,gcs,azure,pg,redis,ldap" \
      --locked -- -D warnings 2>/dev/null; then
      CLIPPY_FAILED=1
    fi
  fi
  if [ "$CLIPPY_FAILED" -ne 0 ]; then
    FAIL=$((FAIL + 1))
    echo "[pre-commit] FAILED: cargo clippy"
  else
    PASS=$((PASS + 1))
  fi
else
  echo ""
  echo "[pre-commit] (2/5) Clippy skipped (SKIP_CLIPPY=1)"
fi

# ── Stage 3: Secret scan ──
if [ "${SKIP_SECRET_SCAN:-0}" != "1" ]; then
  echo ""
  echo "[pre-commit] (3/5) Scanning for hardcoded secrets..."
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
  SECRET_FOUND=0
  if [ -n "$STAGED_FILES" ]; then
    # Check for common secret patterns in staged Rust and TOML files
    for PATTERN in \
      'password\s*=\s*"[^"]*"' \
      'secret\s*=\s*"[^"]*"' \
      'api_key\s*=\s*"[^"]*"' \
      'token\s*=\s*"[^"]*"' \
      'PRIVATE KEY' \
      'BEGIN RSA' \
      'BEGIN EC PRIVATE' \
      'AKIA[0-9A-Z]{16}' \
    ; do
      MATCHES=$(echo "$STAGED_FILES" | grep -E '\.(rs|toml|yaml|yml|json|env|sh|conf|cfg)$' | xargs grep -l "$PATTERN" 2>/dev/null || true)
      if [ -n "$MATCHES" ]; then
        for F in $MATCHES; do
          # Skip test files and example configs
          echo "$F" | grep -qE '(test|example|\.env\.example)' && continue
          echo "[pre-commit] WARNING: Possible secret in $F (pattern: $PATTERN)"
          SECRET_FOUND=1
          WARN=$((WARN + 1))
        done
      fi
    done
  fi
  if [ "$SECRET_FOUND" -eq 0 ]; then
    echo "[pre-commit] No hardcoded secrets detected."
    PASS=$((PASS + 1))
  fi
else
  echo ""
  echo "[pre-commit] (3/5) Secret scan skipped (SKIP_SECRET_SCAN=1)"
fi

# ── Stage 4: TODO/FIXME scan ──
echo ""
echo "[pre-commit] (4/5) Scanning for TODO/FIXME markers..."
TODO_FOUND=0
if [ -n "$STAGED_FILES" ]; then
  TODO_MATCHES=$(echo "$STAGED_FILES" | grep -E '\.rs$' | xargs grep -nE '(todo!|FIXME|HACK|XXX)' 2>/dev/null || true)
  if [ -n "$TODO_MATCHES" ]; then
    echo "[pre-commit] WARNING: Incomplete work markers found:"
    echo "$TODO_MATCHES" | head -10
    TODO_FOUND=1
    WARN=$((WARN + 1))
  fi
fi
if [ "$TODO_FOUND" -eq 0 ]; then
  echo "[pre-commit] No TODO/FIXME markers found."
  PASS=$((PASS + 1))
fi

# ── Stage 5: Tests ──
echo ""
echo "[pre-commit] (5/5) Running tests..."
if [ "${PRECOMMIT_FULL_TESTS:-0}" = "1" ]; then
  echo "[pre-commit] Full test suite requested (PRECOMMIT_FULL_TESTS=1)"
  check_step "cargo test" cargo test --workspace --locked
elif [ "${SKIP_TESTS:-0}" = "1" ]; then
  echo "[pre-commit] Tests skipped (SKIP_TESTS=1)"
else
  # Determine which crates changed (staged files only)
  CHANGED=$(git diff --cached --name-only HEAD 2>/dev/null | grep '^crates/' | cut -d/ -f2 | sort -u || true)
  if [ -z "$CHANGED" ]; then
    echo "[pre-commit] No crate changes detected, skipping tests."
    PASS=$((PASS + 1))
  else
    echo "[pre-commit] Testing changed crates: $(echo $CHANGED | tr '\n' ' ')"
    TEST_FAILED=0
    for CRATE in $CHANGED; do
      # Try ferro-$CRATE first, fall back to bare $CRATE
      if cargo test -p "ferro-${CRATE}" --locked 2>/dev/null; then
        : # pass
      elif cargo test -p "${CRATE}" --locked 2>/dev/null; then
        : # pass
      else
        TEST_FAILED=1
      fi
    done
    if [ "$TEST_FAILED" -ne 0 ]; then
      FAIL=$((FAIL + 1))
      echo "[pre-commit] FAILED: some crate tests failed"
    else
      PASS=$((PASS + 1))
    fi
  fi
fi

# ── Summary ──
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "========================================="
echo "[pre-commit] Results: ${PASS} passed, ${FAIL} failed, ${WARN} warnings (${DURATION}s)"
echo "========================================="

if [ "$FAIL" -gt 0 ]; then
  echo "[pre-commit] Commit blocked. Fix the errors above or use SKIP_PRECOMMIT=1."
  exit 1
fi

if [ "$WARN" -gt 0 ]; then
  echo "[pre-commit] Warnings detected. Review above or proceed with commit."
fi

echo "[pre-commit] All quality gates passed."
