      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (user) (count_over_time({app=\"ferro\", source=\"audit\"} | json [$__range]))",
          "legendFormat": "{{user}}",
          "refId": "A"
        }
      ],
