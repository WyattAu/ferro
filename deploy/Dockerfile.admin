FROM node:20-alpine AS builder
WORKDIR /app
COPY crates/admin/package.json crates/admin/package-lock.json* ./
RUN npm ci
COPY crates/admin/ .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY deploy/nginx-admin.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
