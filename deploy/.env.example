# Ferro Production Stack Configuration
# Copy to .env and fill in your values before deploying.

# ── Ferro ──────────────────────────────────────────────
FERRO_PORT=8080

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────
# No config needed; uses default redis://redis:6379

# ── Caddy (reverse proxy) ─────────────────────────────
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443

# ── Grafana ────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://localhost:3000

# ── Prometheus ─────────────────────────────────────────
PROMETHEUS_RETENTION=30d
